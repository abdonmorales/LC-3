{
  "name": "LC3Tools",
  "version": "2.1.0",
  "author": "Chirag Sakhuja <chirag.sakhuja@utexas.edu>",
  "description": "LC3Tools frontend",
  "license": "MIT",
  "main": "./dist/electron/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/chiragsakhuja/lc3tools.git"
  },
  "scripts": {
    "build": "electron-vite build && electron-builder",
    "build:dir": "electron-vite build && electron-builder --dir",
    "build:mac:universal": "electron-vite build && electron-builder --mac --universal",
    "dev": "electron-vite dev",
    "pack": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "lc3": "electron-rebuild -f -w lc3interface",
    "rebuild:native": "electron-rebuild -f -w lc3interface",
    "rebuild:native:release": "node scripts/rebuild-native-release.js",
    "rebuild:native:universal": "node scripts/rebuild-native-universal.js",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "engines": {
    "node": ">=22"
  },
  "extraResources": "",
  "buildResources": "static",
  "build": {
    "productName": "LC3Tools",
    "appId": "org.devtools.lc3tools",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/electron/**/*",
      "node_modules/**/*",
      "!node_modules/lc3interface/bin/**",
      "package.json",
      "static/icons/*"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "mac": {
      "icon": "static/icons/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "icon": "static/icons/icon.ico",
      "target": ["nsis", "portable"]
    },
    "linux": {
      "icon": "static/icons",
      "category": "Development",
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "chiragsakhuja",
      "repo": "lc3tools"
    }
  },
  "dependencies": {
    "axios": "^1.16.1",
    "brace": "^0.11.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "lc3interface": "file:./local_modules/lc3interface",
    "material-design-icons-iconfont": "^3.0.3",
    "vue": "^2.7.16",
    "vue-router": "^3.6.5",
    "vuetify": "^1.5.24",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@swc/core": "^1.15.33",
    "@vitejs/plugin-vue2": "^2.3.4",
    "electron": "40.10.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.3",
    "vue-template-compiler": "^2.7.16"
  }
}
